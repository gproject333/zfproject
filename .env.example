# Convex
CONVEX_DEPLOYMENT=                  # مثال: dev:your-project-name
NEXT_PUBLIC_CONVEX_URL=             # مثال: https://your-project.convex.cloud

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=  # pk_live_... أو pk_test_...
CLERK_SECRET_KEY=                   # sk_live_... أو sk_test_...
CLERK_WEBHOOK_SECRET=               # whsec_...
CLERK_JWT_ISSUER_DOMAIN=            # مثال: https://your-app.clerk.accounts.dev
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register

# Sentry (اختياري — Sentry يبقى معطّل لو الـ DSN فارغ)
NEXT_PUBLIC_SENTRY_DSN=             # https://xxx@sentry.io/yyy
SENTRY_ORG=                         # zerf-team
SENTRY_PROJECT=                     # smart-zuj
SENTRY_AUTH_TOKEN=                  # token لرفع source maps (CI/CD فقط)
